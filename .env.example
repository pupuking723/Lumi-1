# GoClaw environment variables.
# Copy to .env and fill in values. For Docker Compose, do NOT use 'export' prefix.
#
# Auto-generated by prepare-env.sh: GOCLAW_GATEWAY_TOKEN, GOCLAW_ENCRYPTION_KEY.
# LLM provider API keys: configure via the web dashboard setup wizard.

# --- Gateway (required) ---
GOCLAW_GATEWAY_TOKEN=
GOCLAW_ENCRYPTION_KEY=
POSTGRES_PASSWORD=

# --- C-side Google login ---
# Accepts Google One Tap credentials / ID tokens and Google access tokens at
# POST /v1/auth/google/login. The backend returns its own bearer token for
# authenticated C-side API calls.
GOCLAW_GOOGLE_CLIENT_ID=
# Optional comma-separated extra web/client IDs accepted in Google ID token aud.
# GOCLAW_GOOGLE_CLIENT_IDS=
# Signing secret for GoClaw-issued user session tokens. Defaults to
# GOCLAW_ENCRYPTION_KEY, then GOCLAW_GATEWAY_TOKEN, but production should set it.
# GOCLAW_GOOGLE_AUTH_SESSION_SECRET=
GOCLAW_GOOGLE_AUTH_SESSION_TTL=720h
GOCLAW_GOOGLE_AUTH_USER_ID_PREFIX=google
GOCLAW_GOOGLE_AUTH_TENANT=master
GOCLAW_GOOGLE_AUTH_ROLE=operator
# Optional comma-separated email domains, e.g. example.com,company.com.
# GOCLAW_GOOGLE_AUTH_ALLOWED_DOMAINS=

# --- Database (only for non-Docker deployments) ---
# Docker Compose auto-builds this from POSTGRES_USER/PASSWORD/DB.
# GOCLAW_POSTGRES_DSN=postgres://user:pass@host:5432/dbname?sslmode=disable

# --- Google Vertex AI / Gemini ---
# Either use an OAuth token, service account credentials, or local gcloud ADC.
# GOCLAW_VERTEX_ACCESS_TOKEN=
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
# GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account",...}
# GOCLAW_VERTEX_PROJECT_ID=your-gcp-project-id
# GOCLAW_VERTEX_LOCATION=us-central1

# Independent Gemini Live bridge: /v1/gemini/live/ws and /v1/closy/live/gemini/ws.
GOCLAW_GEMINI_LIVE_AGENT=closy
GOCLAW_GEMINI_LIVE_MODEL=gemini-live-2.5-flash-preview-native-audio-09-2025
GOCLAW_GEMINI_LIVE_PROJECT_ID=
GOCLAW_GEMINI_LIVE_LOCATION=us-central1
GOCLAW_GEMINI_LIVE_API_VERSION=v1beta1
GOCLAW_GEMINI_LIVE_INPUT_MIME=audio/pcm;rate=16000
GOCLAW_GEMINI_LIVE_OUTPUT_MIME=
GOCLAW_GEMINI_LIVE_INPUT_TRANSCRIPTION=true
GOCLAW_GEMINI_LIVE_OUTPUT_TRANSCRIPTION=true
GOCLAW_GEMINI_LIVE_VAD_START_SENSITIVITY=START_SENSITIVITY_HIGH
GOCLAW_GEMINI_LIVE_VAD_END_SENSITIVITY=END_SENSITIVITY_HIGH
GOCLAW_GEMINI_LIVE_VAD_PREFIX_PADDING=150ms
GOCLAW_GEMINI_LIVE_VAD_SILENCE_DURATION=350ms
GOCLAW_GEMINI_LIVE_TIMEOUT=10m

# --- Sandbox (only when using deploy/compose/docker-compose.sandbox.yml) ---
# Docker socket GID: 999 on Linux, 0 on Windows/macOS Docker Desktop.
# DOCKER_GID=0

# --- Debug ---
# GOCLAW_TRACE_VERBOSE=1
